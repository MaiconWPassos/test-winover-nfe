PORT=3000

# Origens do front permitidas no CORS (portas diferentes = cross-origin). Várias: vírgula.
# Em desenvolvimento sem esta variável, a API aceita qualquer Origin (origin: true).
# CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
LOG_LEVEL=info

# Fuso IANA para séries do dashboard (contagem por dia civil). Padrão: America/Sao_Paulo
# STATS_TIMEZONE=America/Sao_Paulo

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nfe
DATABASE_PASSWORD=nfe
DATABASE_NAME=nfe
# DATABASE_URL=postgres://nfe:nfe@localhost:5432/nfe

TYPEORM_SYNC=true

# Emitente (mock) — CNPJ válido de 14 dígitos
EMITENTE_CNPJ=19131243000197
EMITENTE_IE=111222333
EMITENTE_UF=SP

# SEFAZ mock
SEFAZ_MOCK_DELAY_MS=500
SEFAZ_FORCE_REJECT=false

# true = job para após XSD e aguarda POST /webhook/retorno-sefaz (fluxo assíncrono simulado)
# SEFAZ_CALLBACK_MODE=false

# Opcional: exige cabeçalho X-Webhook-Secret igual a este valor em /webhook/retorno-sefaz
# WEBHOOK_SEFAZ_SECRET=
