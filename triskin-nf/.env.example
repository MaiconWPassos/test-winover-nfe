# URL pública da API Nest (browser / fetch para ping e NF-e)
PUBLIC_API_URL=http://localhost:3000

# URL da API só para o servidor Astro (login em /api/auth/login) — no Docker: http://winover-api:3000
API_INTERNAL_URL=http://localhost:3000

# Mesmo segredo da API Nest (validação do JWT no middleware e em /api/auth/session)
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria-igual-a-da-api
