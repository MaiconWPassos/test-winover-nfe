# --- Docker Compose (raiz) — copie para .env ---



# API Nest (NF-e)

NESTJS_API_PORT=3000

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria

DATABASE_USER=nfe

DATABASE_PASSWORD=nfe

DATABASE_NAME=nfe

TYPEORM_SYNC=true



EMITENTE_CNPJ=19131243000197

EMITENTE_IE=111222333

EMITENTE_UF=SP



SEFAZ_MOCK_DELAY_MS=500

SEFAZ_FORCE_REJECT=false

# Opcional: fuso IANA para /nfe/stats (série por dia no dashboard). Padrão no Compose: America/Sao_Paulo
# STATS_TIMEZONE=America/Sao_Paulo

# true = emissão aguarda POST /webhook/retorno-sefaz (simula callback assíncrono)
# SEFAZ_CALLBACK_MODE=false

# Opcional: mesmo valor no header X-Webhook-Secret ao chamar o webhook
# WEBHOOK_SEFAZ_SECRET=



# Frontend Astro — URL da API como o navegador a enxerga (host + porta publicados)

PUBLIC_API_URL=http://localhost:3000

# API Nest — origens CORS (alinhado à porta do site; várias separadas por vírgula)

# CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321



# Porta do site Triskin NF no host (container Astro SSR escuta em 4321)

TRISKIN_WEB_PORT=4321

